# =============================================================================
# FrontFlaskSDD — variables de entorno
# Copia este archivo a `.env` y rellena los valores reales.
# NUNCA commitees el archivo `.env` con credenciales reales.
# =============================================================================

# Cookie de sesión de Flask (cadena aleatoria larga)
SECRET_KEY=cambia_esto_por_una_cadena_aleatoria_muy_larga

# API REST ApiGenericaCsharp
API_BASE_URL=http://localhost:5035

# Mismo endpoint (o uno aislado) para la suite de pruebas de integración
API_BASE_URL_TESTS=http://localhost:5035

# SMTP para recuperación de contraseña (Gmail con App Password recomendado)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=zenith.noreply@gmail.com
SMTP_APP_PASSWORD=xxxx xxxx xxxx xxxx
SMTP_FROM=Zenith <zenith.noreply@gmail.com>

# Modo entorno (true activa SESSION_COOKIE_SECURE y otros endurecimientos)
IS_PRODUCTION=false
